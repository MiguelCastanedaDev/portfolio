---
import ServicesImage from "/images/services-image.png";
import { Image } from "astro:assets";
import Connection from "../assets/icons/connection.svg";
import Divider from "./Divider.astro";
import Designer from "../assets/icons/designer.svg";
import Customer from "../assets/icons/customer.svg";
---

<section class="max-w-5xl mx-auto mt-8 text-center flex flex-col gap-2">
    <div
        class="flex flex-col md:flex-row md:justify-between gap-6 w-full items-start"
    >
        <h3 class="text-2xl text-left font-semibold mt-12 md:max-w-lg">
            Desde sitios informativos hasta plataformas personalizadas,
            desarrollo soluciones digitales flexibles que evolucionan junto con
            tu empresa. 🚀
        </h3>

        <Image
            src={ServicesImage}
            alt="Servicios"
            class="w-full md:w-71 h-auto object-contain"
        />
    </div>
    <div class="flex flex-wrap md:flex-nowrap gap-4 mt-8">
        <div class="flex flex-col gap-6 text-left">
            <Connection />
            <p class="font-medium">
                <b>Haz que tus sistemas trabajen juntos.</b> Integra APIs y servicios
                externos para crear flujos de trabajo conectados, eficientes y adaptados
                a las necesidades de tu empresa.
            </p>
        </div>

        <div class="flex flex-col gap-4 text-left">
            <Designer />
            <p class="font-medium">
                <b>Rediseña tu sitio para crecer más rápido.</b> Mejora la experiencia
                de tus usuarios con interfaces modernas, navegación intuitiva y un
                rendimiento optimizado que impulse tus objetivos de negocio.
            </p>
        </div>

        <div class="flex flex-col gap-4 text-left">
            <Customer />
            <p class="font-medium">
                <b>Convierte visitantes en clientes.</b> Productos enfocados en captar
                leads, reservas o ventas con una experiencia clara y efectiva.
            </p>
        </div>
    </div>

    <Divider />
</section>
