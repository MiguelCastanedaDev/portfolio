---
import Divider from "./Divider.astro";

const year = new Date().getFullYear();
---

<div class="max-w-5xl mx-auto py-6">
    <h3 class="text-xl font-semibold">¿Tienes un proyecto en mente?</h3>

    <p class="mt-2 text-gray-600">
        Desarrollo experiencias web modernas, accesibles y enfocadas en
        resultados.
    </p>

    <a
        href="https://wa.me/5538611026?text=Hola%20Miguel,%20vi%20tu%20portafolio%20y%20me%20gustó%20tu%20trabajo.%20Estoy%20interesado%20en%20desarrollar%20un%20proyecto%20y%20me%20gustaría%20platicar%20contigo%20para%20conocer%20tus%20servicios%20y%20opciones."        class="inline-flex mt-6 px-5 py-3 bg-black text-white rounded-lg hover:opacity-90 transition"
    >
        Hablemos
    </a>
</div>


<div
    class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4"
>

    <div class="text-sm text-gray-500">
        © {year} Miguel Castañeda. Todos los derechos reservados.
    </div>

    <div class="flex items-center gap-6 text-sm">
        <a
            href="https://github.com/MiguelCastanedaDev"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 hover:text-black transition-colors"
        >
            GitHub
        </a>

        <a
            href="https://www.linkedin.com/in/miguel-castaneda-58566623a/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 hover:text-black transition-colors"
        >
            LinkedIn
        </a>

        <a
            href="mailto:mikeonlinemx@gmail.com"
            class="text-gray-600 hover:text-black transition-colors"
        >
            Contacto
        </a>
    </div>
</div>
