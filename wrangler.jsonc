{
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "portfolio",
  "main": "@astrojs/cloudflare/entrypoints/server",

  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },

  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "01c1fa129a6d40949fff11fc00bbb356"
    }
  ],

  "observability": {
    "enabled": true
  }
}